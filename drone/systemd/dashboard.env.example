# Copy to ~/.config/dashboard.env and edit. Keep file mode 600.
#
#   install -m 600 /dev/null ~/.config/dashboard.env
#   $EDITOR ~/.config/dashboard.env

# Where MAVSDK should connect:
#   SITL:       udpin://0.0.0.0:14540
#   USB Pixhawk: serial:///dev/serial/by-id/usb-Auterion_PX4_FMU_v6C.x_0-if00:115200
DRONE_CONN=udpin://0.0.0.0:14540

# Single-user login. If DASHBOARD_PASS is unset, a random one is generated
# at each start and printed to the journal — useful for first run, bad for
# unattended boot. Set both for production.
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-please

# Random 32-byte URL-safe string. Regenerate to invalidate all sessions.
#   python -c 'import secrets;print(secrets.token_urlsafe(32))'
DASHBOARD_SECRET=

# API token used by a remote dashboard UI (MacBook localhost page or other
# browser) to talk to the Pi backend without relying on a browser cookie.
# If unset, the server generates one and prints it at startup.
DASHBOARD_API_TOKEN=

# Listener
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Camera ("none" to disable)
DRONE_CAM=/dev/video0
